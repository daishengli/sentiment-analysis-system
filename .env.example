# JWT 密钥（生产环境请修改）
JWT_SECRET=pulsemind-change-this-secret-in-production

# OpenAI API 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 必填：默认模型
OPENAI_MODEL=gpt-4o-mini

# NewsAPI 配置（用于采集新闻数据）
# 免费注册: https://newsapi.org/register
NEWSAPI_API_KEY=your-newsapi-key-here

# 数据库路径（可选，默认 ./data/pulsemind.db）
# DB_PATH=./data/pulsemind.db
